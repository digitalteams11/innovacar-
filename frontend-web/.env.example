# RentCar SaaS - Frontend Environment Variables
# Copy this file to .env and fill in your values

# Google OAuth 2.0 Client ID
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# API Base URL.
#
# PRODUCTION (Vercel): REQUIRED. Set this in Vercel → Project Settings →
# Environment Variables (not just here — .env files aren't deployed), e.g.:
#   VITE_API_URL=https://api.innovacar.app/api
# Must include the /api suffix — every relative call in the app (e.g.
# api.post('/auth/login')) is appended directly to this base URL, and the
# backend's routes all live under /api/**. Omitting /api here 404s everything.
# Leaving it unset in a production build makes the app fall back to the
# LAN-dev behavior below, which is wrong and blocked as mixed content on https.
#
# LOCAL DEV: optional. When omitted, the app dynamically uses:
# http://<current-browser-host>:8082/api
# This means opening the app at http://192.168.11.197:5174 automatically
# targets http://192.168.11.197:8082/api — no config needed for LAN access.
#
# Set VITE_API_URL only when the backend runs on a DIFFERENT machine or port:
# VITE_API_URL=http://192.168.11.197:8082/api
#
# WARNING: Do NOT set this to http://localhost:8082/api when you need mobile/LAN
# access — phones cannot resolve "localhost" to your PC. Leave it unset instead.
# VITE_API_URL=

# Google Search Console — HTML verification meta tag (alternative to the DNS
# TXT method, see docs/google-search-console-setup.md). Paste the token
# Search Console gives you for the "HTML tag" verification method — NOT the
# whole <meta> tag, just the content="..." value. Injected into the built
# index.html at build time by vite.config.ts. Leave unset if using DNS TXT
# verification instead (no site-wide effect either way — SEO doesn't depend
# on this being set).
VITE_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Optional and NOT
# required for SEO. Not currently wired up — this app has no cookie-consent
# system yet, and analytics must only load after consent (see Part 15 of the
# SEO implementation). Set this once a consent flow exists and analytics
# loading is gated behind it.
VITE_GA_MEASUREMENT_ID=
