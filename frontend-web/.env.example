# RentCar SaaS - Frontend Environment Variables
# Copy this file to .env and fill in your values

# Google OAuth 2.0 Client ID
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# API Base URL.
#
# PRODUCTION (Vercel): REQUIRED. Set this in Vercel → Project Settings →
# Environment Variables (not just here — .env files aren't deployed), e.g.:
#   VITE_API_URL=https://api.innovacar.app/api
# Must include the /api suffix — every relative call in the app (e.g.
# api.post('/auth/login')) is appended directly to this base URL, and the
# backend's routes all live under /api/**. Omitting /api here 404s everything.
# Leaving it unset in a production build makes the app fall back to the
# LAN-dev behavior below, which is wrong and blocked as mixed content on https.
#
# LOCAL DEV: optional. When omitted, the app dynamically uses:
# http://<current-browser-host>:8082/api
# This means opening the app at http://192.168.11.197:5174 automatically
# targets http://192.168.11.197:8082/api — no config needed for LAN access.
#
# Set VITE_API_URL only when the backend runs on a DIFFERENT machine or port:
# VITE_API_URL=http://192.168.11.197:8082/api
#
# WARNING: Do NOT set this to http://localhost:8082/api when you need mobile/LAN
# access — phones cannot resolve "localhost" to your PC. Leave it unset instead.
# VITE_API_URL=

# Google Search Console — HTML verification meta tag (alternative to the DNS
# TXT method, see docs/google-search-console-setup.md). Paste the token
# Search Console gives you for the "HTML tag" verification method — NOT the
# whole <meta> tag, just the content="..." value. Injected into the built
# index.html at build time by vite.config.ts. Leave unset if using DNS TXT
# verification instead (no site-wide effect either way — SEO doesn't depend
# on this being set).
VITE_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX). Optional and NOT
# required for SEO. Not currently wired up — this app has no cookie-consent
# system yet, and analytics must only load after consent (see Part 15 of the
# SEO implementation). Set this once a consent flow exists and analytics
# loading is gated behind it.
VITE_GA_MEASUREMENT_ID=

# Canonical public origin — see src/lib/publicUrl.ts. Required in production
# (Vercel dashboard); defaults to https://innovacar.app if unset. Must be an
# https:// URL and must NEVER be a *.vercel.app preview deployment URL — that
# value is rejected at build time and would otherwise fail
# scripts/verify-seo-dist.mjs (which blocks ".vercel.app" from shipping in
# the production bundle).
VITE_PUBLIC_APP_URL=https://innovacar.app

# ── Innovacar public landing page ───────────────────────────────────────────
# All optional. When unset, the landing page renders safe fallbacks (no
# broken links, no invented offers) instead of a broken/fake element.
# VITE_INNOVAX_WEBSITE_URL and VITE_DESKTOP_DOWNLOAD_URL are validated the
# same way as VITE_PUBLIC_APP_URL above — an https:// URL is required, and a
# *.vercel.app value is silently rejected (renders as "not configured" rather
# than shipping a leaked preview URL).

# Innovax Technologies (parent company) website — rendered as a discreet
# link in the footer/company section. Leave unset until the real domain
# exists; the company name still renders, just without a link. Never point
# this at localhost or an invented domain.
VITE_INNOVAX_WEBSITE_URL=

# Free-trial messaging shown in the hero/CTA/trial sections. The real
# platform grants exactly ONE CALENDAR MONTH of free trial on signup (see
# Tenant.TRIAL_PERIOD_MONTHS in the backend) — keep these in sync with that,
# or with an active promotional campaign your business has actually decided
# to run. Never hardcode a duration/offer here that the backend doesn't honor.
VITE_TRIAL_DURATION_DAYS=30
VITE_TRIAL_LABEL=
VITE_TRIAL_PROMO_ENABLED=false

# Desktop (Windows) application — see frontend_desktop/ in this monorepo.
# Set VITE_DESKTOP_AVAILABLE=true and VITE_DESKTOP_DOWNLOAD_URL once a real
# installer is published somewhere; until then the landing page shows
# "coming soon" instead of a broken download button.
VITE_DESKTOP_AVAILABLE=false
VITE_DESKTOP_DOWNLOAD_URL=
VITE_DESKTOP_PLATFORM=Windows

# Contact section — support email / WhatsApp number (E.164 digits only,
# e.g. 212612345678) / company display name. Leave VITE_CONTACT_WHATSAPP
# unset to hide the WhatsApp button rather than show a broken one.
VITE_CONTACT_EMAIL=
VITE_CONTACT_WHATSAPP=
VITE_COMPANY_NAME=Innovax Technologies
