{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!assets/|brand/|leaflet-images/|favicon\\.svg|icons\\.svg|robots\\.txt|sitemap\\.xml|site\\.webmanifest|fonctionnalites|tarifs).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/((?!sitemap.xml|robots.txt|$|fonctionnalites|tarifs).*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow, noarchive" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
