{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/((?!sitemap.xml|robots.txt).*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow, noarchive" }
      ]
    }
  ]
}
