# RentCar Desktop - Environment Variables
# Copy this file to .env and fill in your values

# Google OAuth 2.0 Client ID
# Get one at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=

# API Base URL. Under Electron's file:// origin there is no usable browser
# hostname to guess from, so this should normally be set explicitly:
# - same machine as the backend: http://localhost:8082/api
# - backend on another machine on the LAN: http://192.168.x.x:8082/api
# If unset, the app falls back to localhost:8082/api.
# This can also be overridden at runtime from inside the app (stored as
# `api_base_url` in localStorage), without rebuilding, for users who need to
# point an already-installed copy at a different backend.
VITE_API_URL=http://localhost:8082/api
