# Local development environment variables for the Spring Boot backend.
#
# Spring Boot does NOT load .env files automatically. This file is
# documentation only — copy the values you need into your shell before
# running the app, e.g. in PowerShell:
#
#   $env:SPRING_DATASOURCE_PASSWORD="your_local_postgres_password"
#   mvn spring-boot:run
#
# Never commit a real .env file — only this .env.example with placeholders.

# ── Database (required) ───────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/location-voiture
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_local_postgres_password

# ── JWT (required in every deployed environment; dev has a fallback) ──────
JWT_SECRET=change-me-local-dev-secret

# ── Optional integrations ──────────────────────────────────────────────────
# GROQ_API_KEY seeds the default Groq provider row on first startup only —
# after that, provider credentials are configured and encrypted in Postgres
# via Super Admin -> AI & Automation -> Providers.
GROQ_API_KEY=
# GEMINI_API_KEY is no longer read at startup (kept only for reference on
# already-migrated installs; see V51 migration).
GEMINI_API_KEY=
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
